<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode: leitet alle Anfragen an server.js (Node.js) weiter -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Statische Dateien aus public/ direkt durch IIS ausliefern -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="^(.+\.(html|css|js|ico|png|jpg|gif|svg|woff|woff2|ttf|map))$" />
          <conditions>
            <add input="{DOCUMENT_ROOT}/public/{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="public/{R:1}" />
        </rule>

        <!-- Alle anderen Anfragen → server.js (Node.js) -->
        <rule name="NodeApp" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- IIS-Buffering für SSE-Stream (/progress) deaktivieren -->
    <!-- Ohne dies kommen Fortschrittsmeldungen erst ganz am Ende an -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Accel-Buffering" value="no" />
      </customHeaders>
    </httpProtocol>

    <!-- Max. Upload-Größe: 50 MB für Excel-Dateien -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

    <!-- iisnode Konfiguration -->
    <!-- flushResponse: SSE-Events sofort senden, nicht puffern  -->
    <!-- maxNamedPipe...: Verbindung stabil halten für 10-Min-Scans -->
    <iisnode
      nodeProcessCommandLine="node.exe"
      loggingEnabled="true"
      logDirectory="iisnode-logs"
      debuggingEnabled="false"
      maxConcurrentRequestsPerProcess="10"
      watchedFiles="server.js"
      flushResponse="true"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="500"
    />

  </system.webServer>
</configuration>
